# Convex deployment URL
VITE_CONVEX_URL=https://YOUR_CONVEX_DEPLOYMENT.convex.cloud

# Convex deploy key (for production deployments)
# CONVEX_DEPLOY_KEY=

# Convex deployment identifier
CONVEX_DEPLOYMENT=dev:YOUR_DEPLOYMENT_ID

# Convex site URL (for server functions)
VITE_CONVEX_SITE_URL=https://YOUR_CONVEX_DEPLOYMENT.convex.site

# Public site URL used by Convex Auth callbacks
SITE_URL=https://YOUR_PUBLIC_APP_URL

# Convex site domain used by auth provider configuration
CONVEX_SITE_URL=https://YOUR_CONVEX_DEPLOYMENT.convex.site
