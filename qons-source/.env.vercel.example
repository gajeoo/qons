# Frontend environment variables for Vercel
# Set these in Vercel Project Settings -> Environment Variables.

# REQUIRED: Convex deployment URL used by the React frontend.
VITE_CONVEX_URL=https://YOUR_CONVEX_DEPLOYMENT.convex.cloud

# REQUIRED for Convex Auth routing/callback behavior.
SITE_URL=https://your-vercel-domain.vercel.app
CONVEX_SITE_URL=https://YOUR_CONVEX_DEPLOYMENT.convex.site

# OPTIONAL: Stripe publishable key for frontend checkout UI.
# If omitted, Stripe UI paths remain disabled.
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx

# OPTIONAL: PayPal client ID for frontend pricing checkout button.
# If omitted, the app attempts to fetch from backend configuration.
VITE_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID

# OPTIONAL: Enables preview-only "Continue as Test User" button.
# Use true only in non-production preview environments.
VITE_IS_PREVIEW=false
